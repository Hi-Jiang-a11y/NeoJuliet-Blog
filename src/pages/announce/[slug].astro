---
import Layout from '../../layouts/Layout.astro';
import BaseHead from '../../components/BaseHead.astro';
import { getCollection, render } from 'astro:content';
import SideAnnouncement from '../../components/Side-Announcement.astro';
import Calendar from '../../components/Calendar.astro';
import CommentSection from '../../components/Giscus.astro';
import ModuleA from '../../components/sidebar/moduleA.astro';
import ModuleB from '../../components/sidebar/moduleB.astro';
import ModuleC from '../../components/sidebar/moduleC.astro';

export async function getStaticPaths() {
  const posts = await getCollection('announce');
  return posts.map(post => ({
    params: { slug: post.id } // ⚠ 用 id 当 URL
  }));
}

// 页面里用 URL param 找 post
const { slug } = Astro.params;
const posts = await getCollection('announce');
const post = posts.find(p => p.id === slug);
if (!post) throw new Error(`Announce post not found: ${slug}`);

// 渲染正文
const { Content } = await render(post);
---
<Layout>
  <BaseHead slot="head" title={post.data.title} description={post.data.description || ""} />

  <div slot="leftbar">
    <ModuleA />
    <ModuleB />
    <ModuleC />
  </div>

  <div slot="rightbar">
    <SideAnnouncement />
    <Calendar />
  </div>

  <h1>{post.data.title} 🎉</h1>
  <p>📅 {post.data.date}</p>

  <article class="announcecontent">
    <Content />
  </article>

  <hr />
  <div class="comment-container">
    <h1>Comments</h1>
    <p>Comment freeeeely</p>
    <CommentSection />
  </div>
</Layout>
