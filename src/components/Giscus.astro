<div id="giscus"></div>

<script>
function loadGiscus() {
    const container = document.getElementById("giscus");
    if (!container) return;

    // 清空旧的 iframe
    container.innerHTML = "";

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;

    script.setAttribute("data-repo", "Hi-Jiang-a11y/NeoJuliet-Blog");
    script.setAttribute("data-repo-id", "R_kgDOQfIuag");
    script.setAttribute("data-category", "Announcements");
    script.setAttribute("data-category-id", "DIC_kwDOQfIuas4C02mZ");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");

    const isDark = document.documentElement.dataset.theme === "dark";
    script.setAttribute("data-theme", isDark ? "dark" : "light_tritanopia");

    script.setAttribute("data-lang", "en");
    script.crossOrigin = "anonymous";

    container.appendChild(script);
}

// 初次加载
loadGiscus();

// ✅ SPA 页面切换时重新加载
document.addEventListener("astro:page-load", loadGiscus);
</script>
